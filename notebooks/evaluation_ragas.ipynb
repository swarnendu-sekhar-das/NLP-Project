{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Phase 5: NLP Evaluation using RAGAS\n",
        "\n",
        "This notebook provides the evaluation framework for the MTech Project: **Procedural QA using RAG for Telecom Service Restoration**.\n",
        "\n",
        "RAGAS (Retrieval Augmented Generation Assessment) is used to calculate academic metrics such as **Faithfulness** (Did the model hallucinate?) and **Answer Relevance** (Did it address the procedural problem without straying?)."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import getpass\n",
        "import nest_asyncio\n",
        "from datasets import Dataset\n",
        "from ragas import evaluate\n",
        "from ragas.metrics import (\n",
        "    faithfulness,\n",
        "    answer_relevancy,\n",
        "    context_precision,\n",
        "    context_recall,\n",
        ")\n",
        "import sys\n",
        "\n",
        "# Ensure the src module is in the path\n",
        "sys.path.append(os.path.abspath(os.path.join(os.getcwd(), \"..\", \"..\")))\n",
        "\n",
        "# Note: RAGAS normally uses OpenAI, but we configure it below for the free Groq API.\n",
        "if \"GROQ_API_KEY\" not in os.environ:\n",
        "    os.environ[\"GROQ_API_KEY\"] = getpass.getpass(\"Enter your Groq API Key: \")\n",
        "\n",
        "# Fix for using async inside Jupyter if necessary\n",
        "nest_asyncio.apply()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Load the QA System\n",
        "Here we load the `ProceduralQAEngine` developed in Phase 4."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from src.retrieval.vector_store import TelecomVectorStore\n",
        "from src.retrieval.hybrid_search import TelecomHybridRetriever\n",
        "from src.llm.qa_engine import ProceduralQAEngine\n",
        "\n",
        "db_path = os.path.abspath(os.path.join(os.getcwd(), \"..\", \"chroma_db\"))\n",
        "vs_manager = TelecomVectorStore(db_path=db_path)\n",
        "retriever = TelecomHybridRetriever(vector_store_manager=vs_manager, similarity_top_k=2)\n",
        "qa_engine = ProceduralQAEngine(retriever_pipeline=retriever)\n",
        "print(\"QA Engine Loaded Successfully.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Generate Evaluation Dataset\n",
        "We create a small ground-truth dataset based on our mock `dummy_nokia_router_mop.md` data."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "test_questions = [\n",
        "    \"How do I fix optical Rx loss on my Nokia router?\",\n",
        "    \"What is the procedure for ALARM_CODE_404 BGP Peer Down?\"\n",
        "]\n",
        "\n",
        "test_answers = [\n",
        "    \"1. Check Optical Levels: show port 1/1/1 optical \\n2. Physical Inspection: inspect the fiber patch cord  \\n3. Clean Fiber: clean both ends of the fiber \\n4. Re-seat SFP: unplug and plug back in \\n5. Replace SFP: Replace the SFP module in port 1/1/1 \\n6. Verify Link: show port 1/1/1\",\n",
        "    \"1. Verify the Alarm Status: show router bgp neighbor status \\n2. Check Logs: show log log-id 99 | match auth \\n3. Validate Key: Contact the BGP peer administrator \\n4. Update Key: configure router bgp group EXTERNAL neighbor 192.168.1.1 and run authentication-key \\n5. Clear Session: clear router bgp protocol \\n6. Final Verification: show router bgp neighbor 192.168.1.1\"\n",
        "]\n",
        "\n",
        "# Run our RAG System to get its proposed answers and retrieved contexts\n",
        "rag_answers = []\n",
        "rag_contexts = []\n",
        "\n",
        "for q in test_questions:\n",
        "    response = qa_engine.query(q)\n",
        "    rag_answers.append(response.response)\n",
        "    # RAGAS expects contexts as a list of strings per question\n",
        "    rag_contexts.append([node.node.get_content() for node in response.source_nodes])\n",
        "\n",
        "# Compile into HuggingFace Dataset format\n",
        "data = {\n",
        "    \"question\": test_questions,\n",
        "    \"answer\": rag_answers,\n",
        "    \"contexts\": rag_contexts,\n",
        "    \"ground_truth\": test_answers\n",
        "}\n",
        "dataset = Dataset.from_dict(data)\n",
        "print(\"Dataset Generation Complete.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Run RAGAS Evaluation\n",
        "Depending on API latency, this may take 1-3 minutes. The resulting DataFrame summarizes the NLP metrics necessary for academic grading."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from langchain_groq import ChatGroq\n",
        "from langchain_huggingface import HuggingFaceEmbeddings\n",
        "\n",
        "# Initialize free Groq LLM and HuggingFace Local Embeddings for RAGAS evaluation\n",
        "eval_llm = ChatGroq(model=\"llama-3.1-8b-instant\")\n",
        "eval_embeddings = HuggingFaceEmbeddings(model_name=\"BAAI/bge-small-en-v1.5\")\n",
        "\n",
        "result = evaluate(\n",
        "    dataset = dataset,\n",
        "    metrics=[\n",
        "        context_precision,\n",
        "        context_recall,\n",
        "        faithfulness,\n",
        "        answer_relevancy,\n",
        "    ],\n",
        "    llm=eval_llm,\n",
        "    embeddings=eval_embeddings,\n",
        ")\n",
        "\n",
        "df = result.to_pandas()\n",
        "df.head()"
      ]
    }
  ],
